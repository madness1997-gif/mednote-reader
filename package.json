{
  "name": "mednote-reader",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build:pages": "vite build --config vite.github.config.ts",
    "build:desktop": "vite build --config vite.desktop.config.ts",
    "dist:win": "npm run build:desktop && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "pdfjs-dist": "5.4.296",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "typescript": "5.9.3",
    "vite": "8.0.13"
  },
  "build": {
    "appId": "vn.mednote.reader",
    "productName": "MedNote Reader",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "MedNote-Reader-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
